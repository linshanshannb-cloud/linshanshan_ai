# Coze 国际版使用 https://api.coze.com
# Coze 中国版可改为 https://api.coze.cn
COZE_API_BASE_URL=https://api.coze.com

# 在 Coze 开放平台创建的 Personal Access Token
COZE_PAT_TOKEN=pat_xxxxxxxxxxxxxxxxx

# 已发布的 Coze Bot ID
COZE_BOT_ID=xxxxxxxxxxxxxxxxx

# 用于标识当前网站访客的稳定字符串（不要填写敏感信息）
COZE_USER_ID=resume_website_visitor
